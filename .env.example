# Database URL (PostgreSQL). Use a connection string from Vercel Postgres,
# Supabase, or Neon. The Prisma schema uses the "postgresql" provider.
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Articles admin (protects /admin). ADMIN_PASSWORD is what the team types at
# /admin/login. ADMIN_SECRET is any long random string used to sign the session
# cookie. Both are required for the articles dashboard to work.
ADMIN_PASSWORD="choose-a-strong-password"
ADMIN_SECRET="a-long-random-string"

# Paystack (powers direct Mobile Money donations with the on-phone PIN prompt).
# Use test keys (sk_test_/pk_test_) while developing, live keys in production.
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_PUBLIC_KEY="pk_test_..."

# Flutterwave (optional alternative for international card donations)
# FLW_SECRET_KEY="FLWSECK_TEST-..."
# FLW_PUBLIC_KEY="FLWPUBK_TEST-..."

# NextAuth (optional - only if you replace the simple admin auth later)
# NEXTAUTH_SECRET="your-secret-here"
# NEXTAUTH_URL="http://localhost:3000"
