# Database URL (SQLite for local dev; use PostgreSQL for Vercel production)
# For Vercel, use a PostgreSQL connection string from Vercel Postgres, Supabase, or Neon
DATABASE_URL="file:./dev.db"

# NextAuth (optional - only if you add authentication later)
# NEXTAUTH_SECRET="your-secret-here"
# NEXTAUTH_URL="http://localhost:3000"

# Paystack (for live donations - add when ready)
# PAYSTACK_SECRET_KEY="sk_test_..."
# PAYSTACK_PUBLIC_KEY="pk_test_..."

# Flutterwave (alternative payment - add when ready)
# FLW_SECRET_KEY="FLWSECK_TEST-..."
# FLW_PUBLIC_KEY="FLWPUBK_TEST-..."
